# Copy this file to secrets.toml and set your own passwords.
# Generate a hash: py -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your_password'))"
#
# Optional: OpenAI for short comparison summaries (also works via OPENAI_API_KEY env var)

openai_api_key = ""

[users]
admin = "REPLACE_WITH_HASH_FROM_WERKZEUG"
